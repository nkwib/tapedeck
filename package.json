{
  "name": "@nkwib/tapedeck",
  "version": "0.2.0",
  "description": "Record/replay middleware for the Vercel AI SDK. Test your agents offline, deterministically, with zero API calls.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tapedeck": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "import": "./dist/vitest.js",
      "require": "./dist/vitest.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "vercel-ai-sdk",
    "ai",
    "agents",
    "testing",
    "vitest",
    "middleware",
    "record-replay",
    "cassette",
    "typescript"
  ],
  "homepage": "https://github.com/nkwib/tapedeck#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nkwib/tapedeck.git"
  },
  "bugs": {
    "url": "https://github.com/nkwib/tapedeck/issues"
  },
  "peerDependencies": {
    "ai": ">=6.0.0 <7",
    "vitest": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/provider": "3.0.10",
    "@types/node": "^22.0.0",
    "ai": "^6.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
